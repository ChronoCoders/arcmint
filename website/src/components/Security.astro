---
const audits = [
  { id: 'C1', label: 'Hardcoded credentials',             status: 'fixed', detail: 'Env vars, no defaults'                      },
  { id: 'C2', label: 'Weak default secrets',               status: 'fixed', detail: 'Min 32-char validation at startup'           },
  { id: 'C3', label: 'TLS validation disabled',            status: 'fixed', detail: 'CA cert required, invalid certs rejected'    },
  { id: 'C4', label: 'Unauthenticated Prometheus metrics', status: 'fixed', detail: 'Bearer OPERATOR_SECRET required'             },
  { id: 'H1', label: 'Services bind 0.0.0.0',             status: 'fixed', detail: '127.0.0.1 default; Docker sets BIND_ADDR'    },
  { id: 'H2', label: 'Plaintext merchant option',         status: 'fixed', detail: 'MERCHANT_INSECURE removed; TLS mandatory'    },
  { id: 'H3', label: 'No /register rate limiting',        status: 'fixed', detail: '10 regs/hr/IP, configurable'                },
  { id: 'H4', label: 'Single static OPERATOR_SECRET',     status: 'fixed', detail: 'Comma-separated rotation; 1h grace period'  },
];

const primitives = [
  { name: 'Domain-separated hashing',        detail: 'arcmint:note:v1, arcmint:identity:v1, arcmint:theta:v1' },
  { name: 'Constant-time comparisons',       detail: 'subtle::ConstantTimeEq on all secret comparisons'       },
  { name: 'Secret zeroization',             detail: 'Scalar, BlindingFactor, UnsignedNote all zeroize on drop' },
  { name: 'Atomic double-spend registry',   detail: 'BEGIN IMMEDIATE + ROLLBACK on all error paths'           },
  { name: 'Atomic wallet writes',           detail: 'temp → fsync → atomic rename'                           },
  { name: 'Protocol versioning',            detail: 'protocol_version: u8 on all wire types, rejected on mismatch' },
  { name: 'Replay protection',              detail: 'Per-session merchant_nonce bound to all spend proofs'    },
  { name: 'Note expiry enforcement',        detail: '90-day window, stamped by coordinator at signing time'   },
];
---

<section id="security" class="relative py-28 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg-base to-bg-surface/30 pointer-events-none"></div>
  <div class="orb w-[500px] h-[500px] bg-green-500/4 top-0 left-0 pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">

    <!-- Heading -->
    <div class="text-center mb-16 reveal">
      <span class="section-eyebrow mb-4">Security</span>
      <h2 class="mt-4 text-4xl sm:text-5xl font-black tracking-tight text-gradient-subtle">
        Production-Grade<br/>
        <span class="text-gradient">Security Posture</span>
      </h2>
      <p class="mt-5 text-lg text-text-secondary max-w-2xl mx-auto">
        ArcMint has undergone a thorough internal security review. All critical and high findings are resolved.
        Zero compiler warnings. No unsafe code.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">

      <!-- Left: Audit table -->
      <div class="reveal">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-bold text-text-primary">Audit Findings</h3>
          <div class="flex items-center gap-1.5">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
            <span class="text-xs text-emerald-400 font-medium">8/8 resolved</span>
          </div>
        </div>
        <div class="rounded-2xl border border-bg-border bg-bg-surface overflow-hidden">
          <div class="divide-y divide-bg-border">
            {audits.map((a) => (
              <div class="flex items-center gap-3 px-5 py-3 hover:bg-bg-raised/50 transition-colors">
                <span class="text-xs font-mono font-bold text-text-dim w-6 flex-shrink-0">{a.id}</span>
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-text-primary font-medium truncate">{a.label}</div>
                  <div class="text-xs text-text-dim">{a.detail}</div>
                </div>
                <span class="badge badge-green flex-shrink-0">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  Fixed
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Cryptographic primitives -->
      <div class="reveal reveal-delay-2 flex flex-col gap-4">
        <h3 class="font-bold text-text-primary">Cryptographic Hardening</h3>

        <div class="flex flex-col gap-2">
          {primitives.map((p) => (
            <div class="flex gap-3 p-4 rounded-xl border border-bg-border bg-bg-surface hover:border-orange/30 transition-colors group">
              <div class="w-5 h-5 rounded-full bg-emerald-400/10 border border-emerald-400/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-semibold text-text-primary">{p.name}</div>
                <div class="text-xs text-text-dim mt-0.5 font-mono">{p.detail}</div>
              </div>
            </div>
          ))}
        </div>

        <!-- Code standards box -->
        <div class="mt-2 rounded-xl border border-orange/20 bg-orange/5 p-5">
          <h4 class="text-sm font-bold text-orange mb-3">Code Standards</h4>
          <div class="grid grid-cols-2 gap-y-2 gap-x-4">
            {[
              'No `unsafe` code',
              'Zero compiler warnings',
              'All errors → Result<T>',
              'Parameterized SQL only',
              'Secrets implement Zeroize',
              'Rust edition 2021',
            ].map((s) => (
              <div class="flex items-center gap-1.5 text-xs text-text-secondary">
                <svg class="w-3 h-3 text-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {s}
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
