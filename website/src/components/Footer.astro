---
const links = {
  Protocol: [
    { label: 'How It Works',    href: '#how-it-works'  },
    { label: 'Architecture',    href: '#architecture'  },
    { label: 'CBN Lifecycle',   href: '#how-it-works'  },
    { label: 'Cryptography',    href: '#security'      },
  ],
  Security: [
    { label: 'Audit Findings',  href: '#security'      },
    { label: 'Code Standards',  href: '#security'      },
    { label: 'Threat Model',    href: '#security'      },
  ],
  Resources: [
    { label: 'GitHub',          href: 'https://github.com/ChronoCoders/arcmint', external: true },
    { label: 'Docker Compose',  href: '#get-started'   },
    { label: 'Get Started',     href: '#get-started'   },
  ],
};
---

<footer class="relative border-t border-bg-border bg-bg-surface/30 overflow-hidden">
  <div class="orb w-[600px] h-[300px] bg-orange/3 top-0 left-1/2 -translate-x-1/2 pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">

    <!-- Top footer -->
    <div class="py-16 grid sm:grid-cols-2 lg:grid-cols-5 gap-10">

      <!-- Brand col -->
      <div class="lg:col-span-2 flex flex-col gap-5">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-orange-gradient flex items-center justify-center">
            <svg viewBox="0 0 20 20" fill="none" class="w-5 h-5">
              <path d="M6 4h5.5a3 3 0 0 1 0 6H6V4Z"  fill="white"/>
              <path d="M6 10h6a3 3 0 0 1 0 6H6V10Z"   fill="white" opacity="0.85"/>
              <rect x="4.5" y="3" width="1.5" height="14" rx="0.75" fill="white"/>
              <rect x="8" y="1.5" width="1.5" height="3"  rx="0.75" fill="white"/>
              <rect x="11" y="1.5" width="1.5" height="3" rx="0.75" fill="white"/>
              <rect x="8" y="15.5" width="1.5" height="3" rx="0.75" fill="white" opacity="0.85"/>
              <rect x="11" y="15.5" width="1.5" height="3" rx="0.75" fill="white" opacity="0.85"/>
            </svg>
          </div>
          <span class="font-bold text-lg text-text-primary tracking-tight">
            Arc<span class="text-orange">Mint</span>
          </span>
        </a>

        <p class="text-sm text-text-secondary leading-relaxed max-w-xs">
          Federated accountable-anonymous e-cash on Bitcoin.
          Private bearer notes backed by BTC, issued by a threshold federation, settled via Lightning.
        </p>

        <div class="flex items-center gap-3 text-xs text-text-dim">
          <span class="badge badge-green">MIT License</span>
          <span class="badge badge-orange">Bitcoin mainnet</span>
        </div>

        <!-- GitHub link -->
        <a
          href="https://github.com/ChronoCoders/arcmint"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 text-sm text-text-secondary hover:text-orange transition-colors w-fit"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          ChronoCoders/arcmint
        </a>
      </div>

      <!-- Links cols -->
      {Object.entries(links).map(([group, items]) => (
        <div class="flex flex-col gap-3">
          <h4 class="text-xs font-semibold text-text-primary uppercase tracking-widest">{group}</h4>
          <div class="flex flex-col gap-2">
            {items.map((item) => (
              <a
                href={item.href}
                target={'external' in item && item.external ? '_blank' : undefined}
                rel={'external' in item && item.external ? 'noopener' : undefined}
                class="text-sm text-text-secondary hover:text-orange transition-colors duration-200 w-fit"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-bg-border to-transparent"></div>

    <!-- Bottom footer -->
    <div class="py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-dim">
        © 2026 ArcMint. Open-source under the MIT License.
      </p>
      <p class="text-xs text-text-dim flex items-center gap-1.5">
        Built on
        <svg class="w-3.5 h-3.5 text-orange" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.638 14.904c-1.602 6.43-8.113 10.34-14.542 8.736C2.67 22.05-1.244 15.525.362 9.105 1.962 2.67 8.475-1.243 14.9.358c6.43 1.605 10.342 8.115 8.738 14.548v-.002zm-6.35-4.613c.24-1.59-.974-2.45-2.64-3.03l.54-2.153-1.315-.33-.525 2.107c-.345-.087-.705-.167-1.064-.25l.526-2.127-1.32-.33-.54 2.165c-.285-.067-.565-.132-.84-.2l-1.815-.45-.35 1.407s.975.225.955.236c.535.136.63.486.615.766l-1.477 5.92c-.075.166-.24.406-.614.314.015.02-.96-.24-.96-.24l-.66 1.51 1.71.426.93.242-.54 2.19 1.32.327.54-2.165c.36.1.705.19 1.05.273l-.51 2.154 1.32.33.545-2.19c2.24.427 3.93.257 4.64-1.774.57-1.637-.03-2.58-1.217-3.196.854-.193 1.5-.76 1.68-1.93h.01zm-3.01 4.22c-.404 1.64-3.157.75-4.05.53l.72-2.9c.896.23 3.757.67 3.33 2.37zm.41-4.24c-.37 1.49-2.662.735-3.405.55l.654-2.64c.744.18 3.137.524 2.75 2.084v.006z"/>
        </svg>
        Bitcoin · Secured by mathematics
      </p>
    </div>
  </div>
</footer>
