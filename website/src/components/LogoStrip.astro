<div class="border-y border-bg-border bg-bg-surface/50">
  <div class="max-w-6xl mx-auto px-6 py-8">
    <p class="text-center text-xs font-medium text-text-dim uppercase tracking-widest mb-6">
      Built on proven cryptographic foundations
    </p>
    <div class="flex flex-wrap justify-center items-center gap-8">
      {techs.map((t) => (
        <div class="flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors duration-200 cursor-default">
          <Fragment set:html={t.icon} />
          <span class="text-sm font-medium whitespace-nowrap">{t.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>
