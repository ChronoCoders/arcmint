---
const links = [
  { label: 'Protocol',     href: '#how-it-works' },
  { label: 'Features',     href: '#features' },
  { label: 'Architecture', href: '#architecture' },
  { label: 'Security',     href: '#security' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 nav-blur border-b border-bg-border/60 bg-bg-base/80">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-lg bg-orange-gradient flex items-center justify-center shadow-orange-sm transition-all duration-300 group-hover:shadow-orange-md">
        <svg viewBox="0 0 20 20" fill="none" class="w-5 h-5">
          <path d="M6 4h5.5a3 3 0 0 1 0 6H6V4Z"  fill="white" opacity="1"/>
          <path d="M6 10h6a3 3 0 0 1 0 6H6V10Z" fill="white" opacity="0.85"/>
          <rect x="4.5" y="3" width="1.5" height="14" rx="0.75" fill="white"/>
          <rect x="8"   y="1.5" width="1.5" height="3"  rx="0.75" fill="white"/>
          <rect x="11"  y="1.5" width="1.5" height="3"  rx="0.75" fill="white"/>
          <rect x="8"   y="15.5" width="1.5" height="3" rx="0.75" fill="white" opacity="0.85"/>
          <rect x="11"  y="15.5" width="1.5" height="3" rx="0.75" fill="white" opacity="0.85"/>
        </svg>
      </div>
      <span class="font-bold text-lg text-text-primary tracking-tight">
        Arc<span class="text-orange">Mint</span>
      </span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          class="px-4 py-2 text-sm font-medium text-text-secondary rounded-lg transition-all duration-200 hover:text-text-primary hover:bg-bg-raised"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href="https://github.com/ChronoCoders/arcmint"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-text-secondary border border-bg-border rounded-lg transition-all duration-200 hover:text-text-primary hover:border-orange/40"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a href="#get-started" class="btn-primary text-sm px-5 py-2">
        Get Started
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="md:hidden p-2 text-text-secondary hover:text-text-primary rounded-lg hover:bg-bg-raised transition-colors"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-bg-border bg-bg-surface">
    <div class="px-6 py-4 flex flex-col gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          class="px-4 py-3 text-sm font-medium text-text-secondary rounded-lg hover:text-text-primary hover:bg-bg-raised transition-all"
        >
          {link.label}
        </a>
      ))}
      <div class="border-t border-bg-border mt-2 pt-3 flex flex-col gap-2">
        <a href="https://github.com/ChronoCoders/arcmint" target="_blank" rel="noopener" class="btn-secondary text-sm justify-center">
          GitHub
        </a>
        <a href="#get-started" class="btn-primary text-sm justify-center">
          Get Started
        </a>
      </div>
    </div>
  </div>
</nav>
