---
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-16">

  <!-- Animated grid background -->
  <div class="absolute inset-0 grid-bg opacity-60 pointer-events-none"></div>

  <!-- Glowing orbs -->
  <div class="orb w-[600px] h-[600px] hero-orb-1 top-[-100px] right-[-100px]"></div>
  <div class="orb w-[400px] h-[400px] hero-orb-2 bottom-[10%] left-[-80px]"></div>
  <div class="orb w-[300px] h-[300px] hero-orb-3 top-[30%] left-[20%]"></div>

  <!-- Radial spotlight -->
  <div class="absolute inset-0 bg-hero-radial pointer-events-none"></div>

  <!-- Vignette -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_40%,#05070a_100%)] pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

    <!-- Left: copy — entry animations via CSS, not IntersectionObserver -->
    <div class="flex flex-col gap-8">

      <!-- Eyebrow -->
      <div class="hero-enter" style="animation-delay:0.1s">
        <span class="section-eyebrow">
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor">
            <circle cx="6" cy="6" r="3"/>
            <circle cx="6" cy="6" r="5.5" fill="none" stroke="currentColor" stroke-width="1"/>
          </svg>
          Open-source · Bitcoin-native · Threshold-secured
        </span>
      </div>

      <!-- Headline -->
      <div class="hero-enter" style="animation-delay:0.25s">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight">
          Private<br/>
          <span class="text-gradient">Bearer Notes</span><br/>
          for Bitcoin
        </h1>
      </div>

      <!-- Subtext -->
      <p class="hero-enter text-lg text-text-secondary leading-relaxed max-w-lg" style="animation-delay:0.45s">
        ArcMint issues cryptographic bearer notes backed by BTC — privately, with full accountability.
        No separate token. No custodial risk. Threshold-secured by a FROST federation, settled via Lightning.
      </p>

      <!-- CTAs -->
      <div class="hero-enter flex flex-wrap items-center gap-4" style="animation-delay:0.6s">
        <a href="#how-it-works" class="btn-primary">
          Explore the Protocol
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
        <a href="https://github.com/ChronoCoders/arcmint" target="_blank" rel="noopener" class="btn-secondary">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Stats row -->
      <div class="hero-enter grid grid-cols-3 gap-4 pt-4 border-t border-bg-border" style="animation-delay:0.75s">
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">2-of-3</div>
          <div class="text-xs text-text-secondary mt-0.5">Threshold signing</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">90d</div>
          <div class="text-xs text-text-secondary mt-0.5">Note validity window</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">0</div>
          <div class="text-xs text-text-secondary mt-0.5">Extra tokens</div>
        </div>
      </div>
    </div>

    <!-- Right: animated federation network SVG -->
    <div class="hero-enter flex items-center justify-center lg:justify-end" style="animation-delay:0.35s">
      <div class="relative w-full max-w-[500px] diagram-float">

        <!-- Outer glow blob -->
        <div class="absolute inset-0 rounded-full diagram-glow pointer-events-none"></div>

        <!--
          SVG uses both href and xlink:href on mpath for cross-browser support.
          Pulse dots travel along <path> elements defined in <defs>.
        -->
        <svg
          viewBox="0 30 500 340"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          class="w-full drop-shadow-2xl"
          style="margin-bottom: -4px;"
        >
          <defs>
            <filter id="coord-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="8" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>

            <linearGradient id="lg-v" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="#f7931a" stop-opacity="0.7"/>
              <stop offset="100%" stop-color="#f7931a" stop-opacity="0.1"/>
            </linearGradient>
            <linearGradient id="lg-r" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#f7931a" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#f7931a" stop-opacity="0.1"/>
            </linearGradient>
            <linearGradient id="lg-l" x1="100%" y1="0%" x2="0%" y2="0%">
              <stop offset="0%" stop-color="#f7931a" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#f7931a" stop-opacity="0.1"/>
            </linearGradient>
            <linearGradient id="cg" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#f7931a"/>
              <stop offset="100%" stop-color="#e8650a"/>
            </linearGradient>

            <!-- Motion paths -->
            <path id="mp-s1" d="M250,220 L250,100"/>
            <path id="mp-s2" d="M250,220 L390,320"/>
            <path id="mp-s3" d="M250,220 L110,320"/>
            <path id="mp-gw" d="M250,220 L100,180"/>
            <path id="mp-me" d="M250,220 L400,180"/>
            <path id="mp-u"  d="M50,260 L100,180"/>
          </defs>

          <!-- ── Connection lines ── -->
          <line x1="250" y1="220" x2="250" y2="100"  stroke="url(#lg-v)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <line x1="250" y1="220" x2="390" y2="320"  stroke="url(#lg-r)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <line x1="250" y1="220" x2="110" y2="320"  stroke="url(#lg-l)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <line x1="250" y1="220" x2="100" y2="180"  stroke="rgba(247,147,26,0.35)" stroke-width="1.5"/>
          <line x1="250" y1="220" x2="400" y2="180"  stroke="rgba(247,147,26,0.35)" stroke-width="1.5"/>
          <line x1="50"  y1="260" x2="100" y2="180"  stroke="rgba(247,147,26,0.2)"  stroke-width="1.5" stroke-dasharray="4 4"/>

          <!-- ── Pulse dots ── -->
          <!-- Coord → Signer 1 (×2) -->
          <circle r="3" fill="#f7931a" opacity="0.9">
            <animateMotion dur="2.4s" repeatCount="indefinite" begin="0s">
              <mpath xlink:href="#mp-s1" href="#mp-s1"/>
            </animateMotion>
          </circle>
          <circle r="3" fill="#f7931a" opacity="0.9">
            <animateMotion dur="2.4s" repeatCount="indefinite" begin="1.2s">
              <mpath xlink:href="#mp-s1" href="#mp-s1"/>
            </animateMotion>
          </circle>

          <!-- Coord → Signer 2 -->
          <circle r="3" fill="#60a5fa" opacity="0.9">
            <animateMotion dur="2.8s" repeatCount="indefinite" begin="0.4s">
              <mpath xlink:href="#mp-s2" href="#mp-s2"/>
            </animateMotion>
          </circle>

          <!-- Coord → Signer 3 -->
          <circle r="3" fill="#60a5fa" opacity="0.9">
            <animateMotion dur="2.8s" repeatCount="indefinite" begin="0.9s">
              <mpath xlink:href="#mp-s3" href="#mp-s3"/>
            </animateMotion>
          </circle>

          <!-- Gateway → Coord (reverse) -->
          <circle r="3" fill="#a78bfa" opacity="0.85">
            <animateMotion dur="2s" repeatCount="indefinite" begin="0.6s"
              keyPoints="1;0" keyTimes="0;1" calcMode="linear">
              <mpath xlink:href="#mp-gw" href="#mp-gw"/>
            </animateMotion>
          </circle>

          <!-- Coord → Merchant -->
          <circle r="3" fill="#f7931a" opacity="0.85">
            <animateMotion dur="2s" repeatCount="indefinite" begin="1s">
              <mpath xlink:href="#mp-me" href="#mp-me"/>
            </animateMotion>
          </circle>

          <!-- User → Gateway -->
          <circle r="2.5" fill="#a78bfa" opacity="0.9">
            <animateMotion dur="1.6s" repeatCount="indefinite" begin="0.2s">
              <mpath xlink:href="#mp-u" href="#mp-u"/>
            </animateMotion>
          </circle>

          <!-- ── Coordinator (center) ── -->
          <!-- Glow ring: SVG-native opacity animation, no CSS transform -->
          <circle cx="250" cy="220" r="46" fill="rgba(247,147,26,0.07)">
            <animate attributeName="opacity" values="0.4;0.9;0.4" dur="3s" repeatCount="indefinite"/>
            <animate attributeName="r"       values="44;50;44"     dur="3s" repeatCount="indefinite"/>
          </circle>
          <circle cx="250" cy="220" r="30" fill="url(#cg)" filter="url(#coord-glow)"/>
          <circle cx="250" cy="220" r="30" fill="none" stroke="rgba(247,147,26,0.5)" stroke-width="1"/>
          <!-- ArcMint logo mark instead of ₿ -->
          <g transform="translate(237,208)">
            <!-- Arch pillars -->
            <rect x="2"  y="14" width="5" height="11" rx="2.5" fill="white"/>
            <rect x="19" y="14" width="5" height="11" rx="2.5" fill="white"/>
            <!-- Arch curve -->
            <path d="M2 16 Q2 4 13.5 4 Q25 4 25 16" stroke="white" stroke-width="3.5" stroke-linecap="round" fill="none"/>
            <!-- Note dot -->
            <circle cx="13.5" cy="5.5" r="3" fill="white" opacity="0.9"/>
          </g>
          <text x="250" y="272" text-anchor="middle" font-size="11" fill="#f7931a" font-weight="600" font-family="Inter, sans-serif">Coordinator</text>

          <!-- ── Signer 1 (top) ── -->
          <circle cx="250" cy="100" r="22" fill="rgba(96,165,250,0.08)"/>
          <circle cx="250" cy="100" r="16" fill="#1e3a5f"/>
          <circle cx="250" cy="100" r="16" fill="none" stroke="#60a5fa" stroke-width="1.5"/>
          <text x="250" y="105" text-anchor="middle" font-size="13" fill="#60a5fa" font-weight="700" font-family="Inter, sans-serif">S1</text>
          <text x="250" y="130" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Signer 1</text>

          <!-- ── Signer 2 (bottom right) ── -->
          <circle cx="390" cy="320" r="22" fill="rgba(96,165,250,0.08)"/>
          <circle cx="390" cy="320" r="16" fill="#1e3a5f"/>
          <circle cx="390" cy="320" r="16" fill="none" stroke="#60a5fa" stroke-width="1.5"/>
          <text x="390" y="325" text-anchor="middle" font-size="13" fill="#60a5fa" font-weight="700" font-family="Inter, sans-serif">S2</text>
          <text x="390" y="351" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Signer 2</text>

          <!-- ── Signer 3 (bottom left) ── -->
          <circle cx="110" cy="320" r="22" fill="rgba(96,165,250,0.08)"/>
          <circle cx="110" cy="320" r="16" fill="#1e3a5f"/>
          <circle cx="110" cy="320" r="16" fill="none" stroke="#60a5fa" stroke-width="1.5"/>
          <text x="110" y="325" text-anchor="middle" font-size="13" fill="#60a5fa" font-weight="700" font-family="Inter, sans-serif">S3</text>
          <text x="110" y="351" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Signer 3</text>

          <!-- ── Gateway (left) ── -->
          <circle cx="100" cy="180" r="20" fill="rgba(167,139,250,0.08)"/>
          <circle cx="100" cy="180" r="14" fill="#1e1b3a"/>
          <circle cx="100" cy="180" r="14" fill="none" stroke="#a78bfa" stroke-width="1.5"/>
          <text x="100" y="185" text-anchor="middle" font-size="10" fill="#a78bfa" font-weight="700" font-family="Inter, sans-serif">GW</text>
          <text x="100" y="208" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Gateway</text>

          <!-- ── Merchant (right) ── -->
          <circle cx="400" cy="180" r="20" fill="rgba(52,211,153,0.08)"/>
          <circle cx="400" cy="180" r="14" fill="#0d2b1f"/>
          <circle cx="400" cy="180" r="14" fill="none" stroke="#34d399" stroke-width="1.5"/>
          <text x="400" y="185" text-anchor="middle" font-size="10" fill="#34d399" font-weight="700" font-family="Inter, sans-serif">ME</text>
          <text x="400" y="208" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Merchant</text>

          <!-- ── User (far left) ── -->
          <circle cx="50" cy="260" r="18" fill="rgba(247,147,26,0.06)"/>
          <circle cx="50" cy="260" r="12" fill="#1c1208"/>
          <circle cx="50" cy="260" r="12" fill="none" stroke="rgba(247,147,26,0.5)" stroke-width="1.5" stroke-dasharray="3 2"/>
          <text x="50" y="265" text-anchor="middle" font-size="9" fill="#f7931a" font-weight="700" font-family="Inter, sans-serif">USR</text>
          <text x="50" y="288" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">User</text>

        </svg>

        <!-- Badge — top-left, clear of all SVG content -->
        <div class="absolute top-2 left-2 badge badge-green text-xs shadow-lg">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Live on Bitcoin mainnet
        </div>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-dim animate-bounce">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  /* ── Hero-specific entry animation (CSS-driven, no IntersectionObserver) ── */
  .hero-enter {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-enter 0.7s ease-out forwards;
  }

  @keyframes hero-enter {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Orbs ── */
  .hero-orb-1 {
    background: rgba(247,147,26,0.10);
    animation: float 9s ease-in-out 1s infinite;
  }
  .hero-orb-2 {
    background: rgba(247,147,26,0.07);
    animation: float 6s ease-in-out infinite;
  }
  .hero-orb-3 {
    background: rgba(59,130,246,0.05);
    animation: float 6s ease-in-out 2s infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-18px); }
  }

  /* ── Diagram float ── */
  .diagram-float {
    animation: float 7s ease-in-out 0.5s infinite;
  }

  /* ── Diagram glow blob ── */
  .diagram-glow {
    background: rgba(247,147,26,0.05);
    filter: blur(60px);
    animation: glow-pulse 4s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: 0.5; }
    50%       { opacity: 1; }
  }
</style>
