---
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-16">

  <!-- Animated grid background -->
  <div class="absolute inset-0 grid-bg opacity-60 pointer-events-none"></div>

  <!-- Glowing orbs -->
  <div class="orb w-[600px] h-[600px] hero-orb-1 top-[-100px] right-[-100px]"></div>
  <div class="orb w-[400px] h-[400px] hero-orb-2 bottom-[10%] left-[-80px]"></div>
  <div class="orb w-[300px] h-[300px] hero-orb-3 top-[30%] left-[20%]"></div>

  <!-- Radial spotlight -->
  <div class="absolute inset-0 bg-hero-radial pointer-events-none"></div>

  <!-- Vignette -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_40%,#05070a_100%)] pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

    <!-- Left: copy -->
    <div class="flex flex-col gap-8">

      <div class="hero-enter" style="animation-delay:0.1s">
        <span class="section-eyebrow">
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor">
            <circle cx="6" cy="6" r="3"/>
            <circle cx="6" cy="6" r="5.5" fill="none" stroke="currentColor" stroke-width="1"/>
          </svg>
          Open-source · Bitcoin-native · Threshold-secured
        </span>
      </div>

      <div class="hero-enter" style="animation-delay:0.25s">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight">
          Private<br/>
          <span class="text-gradient">Bearer Notes</span><br/>
          for Bitcoin
        </h1>
      </div>

      <p class="hero-enter text-lg text-text-secondary leading-relaxed max-w-lg" style="animation-delay:0.45s">
        ArcMint issues cryptographic bearer notes backed by BTC — privately, with full accountability.
        No separate token. No custodial risk. Threshold-secured by a FROST federation, settled via Lightning.
      </p>

      <div class="hero-enter flex flex-wrap items-center gap-4" style="animation-delay:0.6s">
        <a href="/arcmint.pdf" target="_blank" rel="noopener" class="btn-primary">
          Read the Paper
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          </svg>
        </a>
        <a href="https://github.com/ChronoCoders/arcmint" target="_blank" rel="noopener" class="btn-secondary">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <div class="hero-enter grid grid-cols-3 gap-4 pt-4 border-t border-bg-border" style="animation-delay:0.75s">
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">2-of-3</div>
          <div class="text-xs text-text-secondary mt-0.5">Threshold signing</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">90d</div>
          <div class="text-xs text-text-secondary mt-0.5">Note validity window</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">0</div>
          <div class="text-xs text-text-secondary mt-0.5">Extra tokens</div>
        </div>
      </div>
    </div>

    <!-- Right: threshold signature assembly -->
    <div class="hero-enter flex items-center justify-center lg:justify-end" style="animation-delay:0.35s">
      <div class="relative w-full max-w-[480px] diagram-float">

        <div class="absolute inset-0 rounded-full diagram-glow pointer-events-none"></div>

        <svg
          viewBox="0 0 500 410"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          class="w-full drop-shadow-2xl"
        >
          <defs>
            <filter id="glow-center" x="-60%" y="-60%" width="220%" height="220%">
              <feGaussianBlur stdDeviation="10" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow-dot" x="-100%" y="-100%" width="300%" height="300%">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow-node" x="-40%" y="-40%" width="180%" height="180%">
              <feGaussianBlur stdDeviation="6" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>

            <!-- Line gradients: signer color → orange at center -->
            <linearGradient id="lg-s1" x1="250" y1="50" x2="250" y2="200" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#60a5fa"/>
              <stop offset="100%" stop-color="#f7931a"/>
            </linearGradient>
            <linearGradient id="lg-s2" x1="380" y1="275" x2="250" y2="200" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#60a5fa"/>
              <stop offset="100%" stop-color="#f7931a"/>
            </linearGradient>

            <!-- Center fill gradient -->
            <radialGradient id="center-fill" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#ffb347"/>
              <stop offset="100%" stop-color="#e8650a"/>
            </radialGradient>

            <!-- Motion paths: S1 and S2 → center -->
            <path id="mp-s1" d="M250,50 L250,200"/>
            <path id="mp-s2" d="M380,275 L250,200"/>
          </defs>

          <!-- ── Outer orbit ring ── -->
          <circle cx="250" cy="200" r="152" stroke="rgba(247,147,26,0.07)" stroke-width="1" stroke-dasharray="6 5" class="orbit-ring"/>

          <!-- ── Inner triangle connector lines ── -->
          <!-- S1 active: animated glow pulse -->
          <line x1="250" y1="50" x2="250" y2="200" stroke="url(#lg-s1)" stroke-width="1.5" class="line-active"/>
          <!-- S2 active -->
          <line x1="380" y1="275" x2="250" y2="200" stroke="url(#lg-s2)" stroke-width="1.5" class="line-active" style="animation-delay:0.3s"/>
          <!-- S3 inactive: dim dashed -->
          <line x1="120" y1="275" x2="250" y2="200" stroke="rgba(96,165,250,0.12)" stroke-width="1" stroke-dasharray="5 4"/>

          <!-- ── Partial signature labels on active lines ── -->
          <text x="250" y="123" text-anchor="middle" font-size="11" fill="#60a5fa" font-family="JetBrains Mono, monospace" font-weight="500" class="sigma-label">σ₁</text>
          <text x="322" y="232" text-anchor="middle" font-size="11" fill="#60a5fa" font-family="JetBrains Mono, monospace" font-weight="500" class="sigma-label" style="animation-delay:0.4s">σ₂</text>

          <!-- ── Traveling partial-sig dots: S1 → center ── -->
          <circle r="4.5" fill="#f7931a" filter="url(#glow-dot)">
            <animateMotion dur="2.4s" repeatCount="indefinite" begin="0s">
              <mpath xlink:href="#mp-s1" href="#mp-s1"/>
            </animateMotion>
            <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.08;0.92;1" dur="2.4s" repeatCount="indefinite" begin="0s"/>
          </circle>
          <circle r="4.5" fill="#f7931a" filter="url(#glow-dot)">
            <animateMotion dur="2.4s" repeatCount="indefinite" begin="1.2s">
              <mpath xlink:href="#mp-s1" href="#mp-s1"/>
            </animateMotion>
            <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.08;0.92;1" dur="2.4s" repeatCount="indefinite" begin="1.2s"/>
          </circle>

          <!-- ── Traveling partial-sig dots: S2 → center ── -->
          <circle r="4.5" fill="#f7931a" filter="url(#glow-dot)">
            <animateMotion dur="2.7s" repeatCount="indefinite" begin="0.4s">
              <mpath xlink:href="#mp-s2" href="#mp-s2"/>
            </animateMotion>
            <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.08;0.92;1" dur="2.7s" repeatCount="indefinite" begin="0.4s"/>
          </circle>
          <circle r="4.5" fill="#f7931a" filter="url(#glow-dot)">
            <animateMotion dur="2.7s" repeatCount="indefinite" begin="1.75s">
              <mpath xlink:href="#mp-s2" href="#mp-s2"/>
            </animateMotion>
            <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.08;0.92;1" dur="2.7s" repeatCount="indefinite" begin="1.75s"/>
          </circle>

          <!-- ── Center: FROST Signing Chamber ── -->
          <!-- Outer pulsing glow ring -->
          <circle cx="250" cy="200" r="52" fill="rgba(247,147,26,0.07)">
            <animate attributeName="r"       values="48;56;48"   dur="2.8s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.4;0.9;0.4" dur="2.8s" repeatCount="indefinite"/>
          </circle>
          <!-- Middle ring -->
          <circle cx="250" cy="200" r="40" fill="rgba(247,147,26,0.12)" filter="url(#glow-center)">
            <animate attributeName="opacity" values="0.6;1;0.6" dur="2.8s" repeatCount="indefinite"/>
          </circle>
          <!-- Main filled circle -->
          <circle cx="250" cy="200" r="36" fill="url(#center-fill)"/>
          <circle cx="250" cy="200" r="36" fill="none" stroke="rgba(247,147,26,0.7)" stroke-width="1.5"/>

          <!-- ArcMint arch logo mark -->
          <g transform="translate(236,187)">
            <rect x="2"  y="14" width="5"  height="11" rx="2.5" fill="white"/>
            <rect x="21" y="14" width="5"  height="11" rx="2.5" fill="white"/>
            <path d="M2 16 Q2 3 14 3 Q26 3 26 16" stroke="white" stroke-width="3.5" stroke-linecap="round" fill="none"/>
            <circle cx="14" cy="4.5" r="3" fill="white" opacity="0.9"/>
          </g>

          <text x="250" y="256" text-anchor="middle" font-size="11" fill="#f7931a" font-weight="700" font-family="Inter, sans-serif" letter-spacing="0.03em">FROST Coordinator</text>

          <!-- ── 2-of-3 threshold badge ── -->
          <rect x="188" y="268" width="124" height="24" rx="12" fill="rgba(247,147,26,0.1)" stroke="rgba(247,147,26,0.35)" stroke-width="1"/>
          <text x="250" y="284" text-anchor="middle" font-size="10.5" fill="#f7931a" font-weight="600" font-family="Inter, sans-serif">2-of-3 threshold met</text>

          <!-- ── Signer 1 — top, active ── -->
          <circle cx="250" cy="50" r="30" fill="rgba(96,165,250,0.06)" filter="url(#glow-node)">
            <animate attributeName="r"       values="26;33;26"   dur="2.5s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.3;0.7;0.3" dur="2.5s" repeatCount="indefinite"/>
          </circle>
          <circle cx="250" cy="50" r="22" fill="#0b1929"/>
          <circle cx="250" cy="50" r="22" fill="none" stroke="#60a5fa" stroke-width="2"/>
          <!-- Key icon -->
          <g transform="translate(239,39)">
            <circle cx="7" cy="7" r="4.5" fill="none" stroke="#60a5fa" stroke-width="1.8"/>
            <line x1="10" y1="10" x2="15" y2="15" stroke="#60a5fa" stroke-width="1.8" stroke-linecap="round"/>
            <line x1="13.5" y1="13.5" x2="13.5" y2="16.5" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="15" y1="15" x2="15" y2="18" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round"/>
          </g>
          <!-- Active badge -->
          <circle cx="266" cy="35" r="6" fill="#34d399"/>
          <text x="266" y="39.5" text-anchor="middle" font-size="8.5" fill="white" font-weight="800" font-family="Inter, sans-serif">✓</text>
          <text x="250" y="86" text-anchor="middle" font-size="11" fill="#60a5fa" font-weight="600" font-family="Inter, sans-serif">Signer 1</text>

          <!-- ── Signer 2 — bottom-right, active ── -->
          <circle cx="380" cy="275" r="30" fill="rgba(96,165,250,0.06)" filter="url(#glow-node)">
            <animate attributeName="r"       values="26;33;26"   dur="2.9s" repeatCount="indefinite" begin="0.5s"/>
            <animate attributeName="opacity" values="0.3;0.7;0.3" dur="2.9s" repeatCount="indefinite" begin="0.5s"/>
          </circle>
          <circle cx="380" cy="275" r="22" fill="#0b1929"/>
          <circle cx="380" cy="275" r="22" fill="none" stroke="#60a5fa" stroke-width="2"/>
          <g transform="translate(369,264)">
            <circle cx="7" cy="7" r="4.5" fill="none" stroke="#60a5fa" stroke-width="1.8"/>
            <line x1="10" y1="10" x2="15" y2="15" stroke="#60a5fa" stroke-width="1.8" stroke-linecap="round"/>
            <line x1="13.5" y1="13.5" x2="13.5" y2="16.5" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="15" y1="15" x2="15" y2="18" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round"/>
          </g>
          <circle cx="396" cy="260" r="6" fill="#34d399"/>
          <text x="396" y="264.5" text-anchor="middle" font-size="8.5" fill="white" font-weight="800" font-family="Inter, sans-serif">✓</text>
          <text x="380" y="311" text-anchor="middle" font-size="11" fill="#60a5fa" font-weight="600" font-family="Inter, sans-serif">Signer 2</text>

          <!-- ── Signer 3 — bottom-left, standby (not needed) ── -->
          <circle cx="120" cy="275" r="22" fill="#08101a"/>
          <circle cx="120" cy="275" r="22" fill="none" stroke="#2a3a4d" stroke-width="1.5" stroke-dasharray="4 3"/>
          <g transform="translate(109,264)" opacity="0.35">
            <circle cx="7" cy="7" r="4.5" fill="none" stroke="#4a6070" stroke-width="1.8"/>
            <line x1="10" y1="10" x2="15" y2="15" stroke="#4a6070" stroke-width="1.8" stroke-linecap="round"/>
            <line x1="13.5" y1="13.5" x2="13.5" y2="16.5" stroke="#4a6070" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="15" y1="15" x2="15" y2="18" stroke="#4a6070" stroke-width="1.5" stroke-linecap="round"/>
          </g>
          <text x="120" y="311" text-anchor="middle" font-size="11" fill="#3a4f62" font-weight="500" font-family="Inter, sans-serif">Signer 3</text>
          <text x="120" y="326" text-anchor="middle" font-size="9.5" fill="#2d3f50" font-family="Inter, sans-serif">standby</text>

          <!-- ── Triangle edges between signers (very subtle) ── -->
          <line x1="250" y1="72" x2="362" y2="257" stroke="rgba(96,165,250,0.06)" stroke-width="1"/>
          <line x1="250" y1="72" x2="138" y2="257" stroke="rgba(96,165,250,0.06)" stroke-width="1"/>
          <line x1="142" y1="275" x2="358" y2="275" stroke="rgba(96,165,250,0.06)" stroke-width="1"/>

        </svg>

        <!-- Badge -->
        <div class="absolute top-2 left-2 badge badge-green text-xs shadow-lg">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Live on Bitcoin mainnet
        </div>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-dim animate-bounce">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  /* ── Hero entry animation ── */
  .hero-enter {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-enter 0.7s ease-out forwards;
  }
  @keyframes hero-enter {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Orbs ── */
  .hero-orb-1 { background: rgba(247,147,26,0.10); animation: float 9s ease-in-out 1s infinite; }
  .hero-orb-2 { background: rgba(247,147,26,0.07); animation: float 6s ease-in-out infinite; }
  .hero-orb-3 { background: rgba(59,130,246,0.05);  animation: float 6s ease-in-out 2s infinite; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-18px); }
  }

  /* ── Diagram float ── */
  .diagram-float { animation: float 7s ease-in-out 0.5s infinite; }

  /* ── Diagram glow blob ── */
  .diagram-glow {
    background: rgba(247,147,26,0.05);
    filter: blur(60px);
    animation: glow-pulse 4s ease-in-out infinite;
  }
  @keyframes glow-pulse {
    0%, 100% { opacity: 0.5; }
    50%       { opacity: 1; }
  }

  /* ── Orbit ring slow rotation ── */
  .orbit-ring {
    transform-box: fill-box;
    transform-origin: center;
    animation: orbit-spin 30s linear infinite;
  }
  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ── Active signer lines glow pulse ── */
  .line-active {
    animation: line-glow 2.5s ease-in-out infinite;
  }
  @keyframes line-glow {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }

  /* ── Partial sig labels fade pulse ── */
  .sigma-label {
    animation: sigma-pulse 2.5s ease-in-out infinite;
  }
  @keyframes sigma-pulse {
    0%, 100% { opacity: 0.3; }
    50%       { opacity: 0.9; }
  }
</style>
