---
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-16">

  <!-- Animated grid background -->
  <div class="absolute inset-0 grid-bg opacity-60 pointer-events-none"></div>

  <!-- Glowing orbs -->
  <div class="orb w-[600px] h-[600px] bg-orange/10 top-[-100px] right-[-100px] animate-float-slow"></div>
  <div class="orb w-[400px] h-[400px] bg-orange/6 bottom-[10%] left-[-80px] animate-float"></div>
  <div class="orb w-[300px] h-[300px] bg-blue-500/5 top-[30%] left-[20%] animate-float-delay"></div>

  <!-- Radial spotlight -->
  <div class="absolute inset-0 bg-hero-radial pointer-events-none"></div>

  <!-- Vignette -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_40%,#05070a_100%)] pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

    <!-- Left: copy -->
    <div class="flex flex-col gap-8">
      <!-- Eyebrow -->
      <div class="reveal">
        <span class="section-eyebrow">
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor">
            <circle cx="6" cy="6" r="3"/>
            <circle cx="6" cy="6" r="5.5" fill="none" stroke="currentColor" stroke-width="1"/>
          </svg>
          Open-source · Bitcoin-native · Threshold-secured
        </span>
      </div>

      <!-- Headline -->
      <div class="reveal reveal-delay-1">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight">
          Private<br/>
          <span class="text-gradient">Bearer Notes</span><br/>
          for Bitcoin
        </h1>
      </div>

      <!-- Subtext -->
      <p class="reveal reveal-delay-2 text-lg text-text-secondary leading-relaxed max-w-lg">
        ArcMint issues cryptographic bearer notes backed by BTC — privately, with full accountability.
        No separate token. No custodial risk. Threshold-secured by a FROST federation, settled via Lightning.
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-delay-3 flex flex-wrap items-center gap-4">
        <a href="#how-it-works" class="btn-primary">
          Explore the Protocol
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
        <a
          href="https://github.com/ChronoCoders/arcmint"
          target="_blank"
          rel="noopener"
          class="btn-secondary"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Stats row -->
      <div class="reveal reveal-delay-4 grid grid-cols-3 gap-4 pt-4 border-t border-bg-border">
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">2-of-3</div>
          <div class="text-xs text-text-secondary mt-0.5">Threshold signing</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">90d</div>
          <div class="text-xs text-text-secondary mt-0.5">Note validity window</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary tabular-nums">0</div>
          <div class="text-xs text-text-secondary mt-0.5">Extra tokens</div>
        </div>
      </div>
    </div>

    <!-- Right: animated federation network SVG -->
    <div class="reveal reveal-delay-2 flex items-center justify-center lg:justify-end">
      <div class="relative w-full max-w-[500px] animate-float">

        <!-- Outer glow ring -->
        <div class="absolute inset-0 rounded-full bg-orange/5 blur-3xl animate-glow-ring pointer-events-none"></div>

        <svg viewBox="0 0 500 440" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full drop-shadow-2xl">
          <defs>
            <!-- Coordinator glow filter -->
            <filter id="coordinator-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="8" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="node-glow" x="-60%" y="-60%" width="220%" height="220%">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>

            <!-- Gradient for connection lines -->
            <linearGradient id="line-gradient-1" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#f7931a" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#f7931a" stop-opacity="0.1"/>
            </linearGradient>
            <linearGradient id="line-gradient-2" x1="100%" y1="0%" x2="0%" y2="0%">
              <stop offset="0%" stop-color="#f7931a" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#f7931a" stop-opacity="0.1"/>
            </linearGradient>
            <linearGradient id="line-gradient-v" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="#f7931a" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#f7931a" stop-opacity="0.1"/>
            </linearGradient>
            <linearGradient id="signer-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#60a5fa"/>
              <stop offset="100%" stop-color="#3b82f6"/>
            </linearGradient>
            <linearGradient id="coord-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#f7931a"/>
              <stop offset="100%" stop-color="#e8650a"/>
            </linearGradient>

            <!-- Path definitions for animateMotion -->
            <path id="p-c-s1" d="M250,220 L250,100"/>
            <path id="p-c-s2" d="M250,220 L390,320"/>
            <path id="p-c-s3" d="M250,220 L110,320"/>
            <path id="p-c-gw" d="M250,220 L100,180"/>
            <path id="p-c-me" d="M250,220 L400,180"/>
            <path id="p-u-gw"  d="M50,260 L100,180"/>
          </defs>

          <!-- ── Connection lines ───────────────── -->
          <!-- Coordinator → Signer 1 -->
          <line x1="250" y1="220" x2="250" y2="100" stroke="url(#line-gradient-v)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <!-- Coordinator → Signer 2 -->
          <line x1="250" y1="220" x2="390" y2="320" stroke="url(#line-gradient-1)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <!-- Coordinator → Signer 3 -->
          <line x1="250" y1="220" x2="110" y2="320" stroke="url(#line-gradient-2)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <!-- Coordinator → Gateway -->
          <line x1="250" y1="220" x2="100" y2="180" stroke="rgba(247,147,26,0.3)" stroke-width="1.5"/>
          <!-- Coordinator → Merchant -->
          <line x1="250" y1="220" x2="400" y2="180" stroke="rgba(247,147,26,0.3)" stroke-width="1.5"/>
          <!-- User → Gateway -->
          <line x1="50" y1="260" x2="100" y2="180" stroke="rgba(247,147,26,0.2)" stroke-width="1.5" stroke-dasharray="4 4"/>

          <!-- ── Animated pulses ────────────────── -->
          <!-- Coordinator → Signer 1 -->
          <circle r="3" fill="#f7931a" opacity="0.9">
            <animateMotion dur="2.4s" repeatCount="indefinite" begin="0s">
              <mpath href="#p-c-s1"/>
            </animateMotion>
          </circle>
          <circle r="3" fill="#f7931a" opacity="0.9">
            <animateMotion dur="2.4s" repeatCount="indefinite" begin="1.2s">
              <mpath href="#p-c-s1"/>
            </animateMotion>
          </circle>

          <!-- Coordinator → Signer 2 -->
          <circle r="3" fill="#60a5fa" opacity="0.9">
            <animateMotion dur="2.8s" repeatCount="indefinite" begin="0.4s">
              <mpath href="#p-c-s2"/>
            </animateMotion>
          </circle>

          <!-- Coordinator → Signer 3 -->
          <circle r="3" fill="#60a5fa" opacity="0.9">
            <animateMotion dur="2.8s" repeatCount="indefinite" begin="0.8s">
              <mpath href="#p-c-s3"/>
            </animateMotion>
          </circle>

          <!-- Gateway → Coordinator -->
          <circle r="3" fill="#f7931a" opacity="0.8">
            <animateMotion dur="2s" repeatCount="indefinite" begin="0.6s" keyPoints="1;0" keyTimes="0;1" calcMode="linear">
              <mpath href="#p-c-gw"/>
            </animateMotion>
          </circle>

          <!-- Coordinator → Merchant -->
          <circle r="3" fill="#f7931a" opacity="0.8">
            <animateMotion dur="2s" repeatCount="indefinite" begin="1s">
              <mpath href="#p-c-me"/>
            </animateMotion>
          </circle>

          <!-- User → Gateway -->
          <circle r="2.5" fill="#a78bfa" opacity="0.9">
            <animateMotion dur="1.6s" repeatCount="indefinite" begin="0.2s">
              <mpath href="#p-u-gw"/>
            </animateMotion>
          </circle>

          <!-- ── Node: Coordinator (center) ────── -->
          <circle cx="250" cy="220" r="44" fill="rgba(247,147,26,0.08)" class="animate-glow-ring"/>
          <circle cx="250" cy="220" r="30" fill="url(#coord-gradient)" filter="url(#coordinator-glow)"/>
          <circle cx="250" cy="220" r="30" fill="none" stroke="rgba(247,147,26,0.5)" stroke-width="1"/>
          <!-- Bitcoin symbol -->
          <text x="250" y="227" text-anchor="middle" font-size="22" font-weight="bold" fill="white" font-family="serif">₿</text>
          <!-- Label -->
          <text x="250" y="272" text-anchor="middle" font-size="11" fill="#f7931a" font-weight="600" font-family="Inter, sans-serif">Coordinator</text>

          <!-- ── Node: Signer 1 (top) ────────── -->
          <circle cx="250" cy="100" r="22" fill="rgba(96,165,250,0.1)"/>
          <circle cx="250" cy="100" r="16" fill="#1e3a5f"/>
          <circle cx="250" cy="100" r="16" fill="none" stroke="#60a5fa" stroke-width="1.5"/>
          <text x="250" y="105" text-anchor="middle" font-size="13" fill="#60a5fa" font-weight="700" font-family="Inter, sans-serif">S1</text>
          <text x="250" y="130" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Signer 1</text>

          <!-- ── Node: Signer 2 (bottom right) ── -->
          <circle cx="390" cy="320" r="22" fill="rgba(96,165,250,0.1)"/>
          <circle cx="390" cy="320" r="16" fill="#1e3a5f"/>
          <circle cx="390" cy="320" r="16" fill="none" stroke="#60a5fa" stroke-width="1.5"/>
          <text x="390" y="325" text-anchor="middle" font-size="13" fill="#60a5fa" font-weight="700" font-family="Inter, sans-serif">S2</text>
          <text x="390" y="351" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Signer 2</text>

          <!-- ── Node: Signer 3 (bottom left) ── -->
          <circle cx="110" cy="320" r="22" fill="rgba(96,165,250,0.1)"/>
          <circle cx="110" cy="320" r="16" fill="#1e3a5f"/>
          <circle cx="110" cy="320" r="16" fill="none" stroke="#60a5fa" stroke-width="1.5"/>
          <text x="110" y="325" text-anchor="middle" font-size="13" fill="#60a5fa" font-weight="700" font-family="Inter, sans-serif">S3</text>
          <text x="110" y="351" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Signer 3</text>

          <!-- ── Node: Gateway (left) ─────────── -->
          <circle cx="100" cy="180" r="20" fill="rgba(167,139,250,0.1)"/>
          <circle cx="100" cy="180" r="14" fill="#1e1b3a"/>
          <circle cx="100" cy="180" r="14" fill="none" stroke="#a78bfa" stroke-width="1.5"/>
          <text x="100" y="185" text-anchor="middle" font-size="10" fill="#a78bfa" font-weight="700" font-family="Inter, sans-serif">GW</text>
          <text x="100" y="208" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Gateway</text>

          <!-- ── Node: Merchant (right) ──────── -->
          <circle cx="400" cy="180" r="20" fill="rgba(52,211,153,0.1)"/>
          <circle cx="400" cy="180" r="14" fill="#0d2b1f"/>
          <circle cx="400" cy="180" r="14" fill="none" stroke="#34d399" stroke-width="1.5"/>
          <text x="400" y="185" text-anchor="middle" font-size="10" fill="#34d399" font-weight="700" font-family="Inter, sans-serif">ME</text>
          <text x="400" y="208" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Merchant</text>

          <!-- ── Node: User (far left) ────────── -->
          <circle cx="50" cy="260" r="18" fill="rgba(247,147,26,0.08)"/>
          <circle cx="50" cy="260" r="12" fill="#1c1208"/>
          <circle cx="50" cy="260" r="12" fill="none" stroke="rgba(247,147,26,0.5)" stroke-width="1.5" stroke-dasharray="3 2"/>
          <text x="50" y="265" text-anchor="middle" font-size="9" fill="#f7931a" font-weight="700" font-family="Inter, sans-serif">USR</text>
          <text x="50" y="288" text-anchor="middle" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">User</text>

          <!-- ── Legend ─────────────────────── -->
          <g transform="translate(310, 370)">
            <rect width="150" height="56" rx="8" fill="rgba(13,17,23,0.8)" stroke="rgba(30,45,61,0.8)" stroke-width="1"/>
            <circle cx="16" cy="16" r="5" fill="url(#coord-gradient)"/>
            <text x="28" y="20" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Coordinator</text>
            <circle cx="16" cy="36" r="5" fill="#1e3a5f" stroke="#60a5fa" stroke-width="1.5"/>
            <text x="28" y="40" font-size="10" fill="#7d8fa3" font-family="Inter, sans-serif">Signer (FROST)</text>
          </g>
        </svg>

        <!-- Floating badge -->
        <div class="absolute -bottom-2 -right-2 sm:bottom-4 sm:right-0 badge badge-green text-xs shadow-lg">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Live on Bitcoin mainnet
        </div>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-dim animate-bounce">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
