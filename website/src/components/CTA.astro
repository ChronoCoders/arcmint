---
---

<section id="get-started" class="relative py-28 overflow-hidden">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg-base via-bg-raised/40 to-bg-base pointer-events-none"></div>
  <div class="orb w-[800px] h-[500px] bg-orange/8 top-1/2 -translate-y-1/2 left-1/2 -translate-x-1/2 pointer-events-none"></div>
  <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6">

    <div class="reveal rounded-3xl border border-bg-border bg-bg-surface/50 overflow-hidden">
      <!-- Gradient top border -->
      <div class="h-px bg-gradient-to-r from-transparent via-orange/60 to-transparent"></div>

      <div class="p-10 sm:p-14 flex flex-col items-center text-center gap-8">

        <!-- Icon -->
        <div class="w-16 h-16 rounded-2xl bg-orange-gradient flex items-center justify-center shadow-orange-lg animate-pulse-orange">
          <svg viewBox="0 0 32 32" fill="none" class="w-9 h-9">
            <rect x="4" y="18" width="5.5" height="11" rx="2.75" fill="white"/>
            <rect x="22.5" y="18" width="5.5" height="11" rx="2.75" fill="white"/>
            <path d="M4 21 Q4 4 16 4 Q28 4 28 21" stroke="white" stroke-width="3.5" stroke-linecap="round" fill="none"/>
            <circle cx="16" cy="7" r="3.5" fill="white" opacity="0.95"/>
          </svg>
        </div>

        <!-- Headline -->
        <div>
          <h2 class="text-4xl sm:text-5xl font-black tracking-tight">
            Deploy Your<br/>
            <span class="text-gradient">Federation Today</span>
          </h2>
          <p class="mt-5 text-lg text-text-secondary max-w-xl mx-auto leading-relaxed">
            A full ArcMint federation — Bitcoin node, Lightning, threshold signers, gateway, and merchant —
            launches with a single Docker Compose command.
          </p>
        </div>

        <!-- Docker command box -->
        <div class="w-full max-w-2xl code-block">
          <div class="code-block-header">
            <div class="code-dot bg-red-500/70"></div>
            <div class="code-dot bg-yellow-400/70"></div>
            <div class="code-dot bg-green-400/70"></div>
            <span class="ml-2 text-xs font-mono text-text-dim">Terminal</span>
          </div>
          <div class="p-5 font-mono text-sm leading-relaxed">
            <div class="flex gap-3 mb-2">
              <span class="text-text-dim select-none">$</span>
              <span class="text-text-secondary">git clone https://github.com/ChronoCoders/arcmint</span>
            </div>
            <div class="flex gap-3 mb-2">
              <span class="text-text-dim select-none">$</span>
              <span class="text-text-secondary">cp .env.example .env <span class="text-text-dim"># fill in secrets</span></span>
            </div>
            <div class="flex gap-3">
              <span class="text-text-dim select-none">$</span>
              <span class="text-orange">docker compose up -d</span>
            </div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="https://github.com/ChronoCoders/arcmint"
            target="_blank"
            rel="noopener"
            class="btn-primary"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
          <a href="/arcmint.pdf" target="_blank" rel="noopener" class="btn-secondary">
            Read the Paper
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Fine print -->
        <p class="text-xs text-text-dim">
          Open-source under MIT license · Requires Docker · Bitcoin mainnet or regtest
        </p>
      </div>

      <!-- Gradient bottom border -->
      <div class="h-px bg-gradient-to-r from-transparent via-orange/60 to-transparent"></div>
    </div>

  </div>
</section>
